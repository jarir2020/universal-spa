{
    "name": "jarir-ahmed/universal-spa",
    "description": "A framework-agnostic Single Page Application (SPA) engine for PHP",
    "type": "library",
    "license": "MIT",
    "keywords": ["spa", "pjax", "html", "navigation"],
    "authors": [
        {
            "name": "Jarir Ahmed",
            "email": "jarircse16@gmail.com"
        }
    ],
    "require": {
        "php": ">=7.4.0",
        "ext-dom": "*",
        "ext-libxml": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "JarirAhmed\\UniversalSpa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JarirAhmed\\UniversalSpa\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
